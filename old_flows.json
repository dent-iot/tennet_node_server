        "type": "function",
        "z": "e237f4a1.bd2cd",
        "name": "ready4plot",
        "func": "var values = msg.payload; // Example values\nvalues.splice(0, 1);\nglobal.set(\"firstMessage\", values);\nvar data = [];\nfor (var i = 0; i < values.length; i++) {\n    values[i] = (values[i] - 1150)/1900 * 0.7;\n    data.push({x: i, y: values[i]});\n}\nmsg.payload = [{\n    series: ['Current'], // Label for the data series\n    data: [data], // Array of data points (each point is an object with x and y properties)\n}];\n\nreturn msg;\n",
