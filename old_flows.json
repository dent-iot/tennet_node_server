    {
        "id": "e8cba28ff0928ead",
        "type": "function",
        "z": "e237f4a1.bd2cd",
        "name": "coupleArrays",
        "func": "// Assuming msg.payload contains an array of values\nvar msg1 = global.get(\"firstMessage\");;\nvar msg2 = global.get(\"secondMessage\");\nvar msg3 = global.get(\"thirdMessage\");\nvar msg4 = global.get(\"fourthMessage\");\nvar msg5 = global.get(\"fifthMessage\");\nvar msg6 = global.get(\"sixthMessage\");\nvar msg7 = global.get(\"seventhMessage\");\nvar msg8 = global.get(\"eighthMessage\");\n\nvar data = [];\nvar multiplier = 1;\nvar j = 0;\nfor (var i = 0; i < msg1.length -1; i++) {\n    data.push({ x: j*multiplier, y: msg1[i]});\n    j++\n}\nfor (var i = 0; i < msg2.length -1 ; i++) {\n    data.push({ x: j*multiplier, y: msg2[i]});\n    j++;\n}\nfor (var i = 0; i < msg3.length -1; i++) {\n    data.push({ x: j*multiplier, y: msg3[i]});\n    j++;\n}\nfor (var i = 0; i < msg4.length - 1; i++) {\n    data.push({ x: j * multiplier, y: msg4[i] });\n    j++;\n}\nfor (var i = 0; i < msg5.length - 1; i++) {\n    data.push({ x: j * multiplier, y: msg5[i] });\n    j++;\n} \nfor (var i = 0; i < msg6.length - 1; i++) {\n    data.push({ x: j * multiplier, y: msg6[i] });\n    j++;\n}\nfor (var i = 0; i < msg7.length - 1; i++) {\n    data.push({ x: j * multiplier, y: msg7[i] });\n    j++;\n}\nfor (var i = 0; i < msg8.length - 1; i++) {\n    data.push({ x: j * multiplier, y: msg8[i] });\n    j++;\n}\n\nmsg.payload = [{\n    series: ['Current'], // Label for the data series\n    data: [data], // Array of data points (each point is an object with x and y properties)\n}];\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1410,
        "y": 1000,
        "wires": [
            [
                "94aebcca8a43b533"
            ]
        ]
    },
