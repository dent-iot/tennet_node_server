    {
        "id": "392a8c0d5b7556ba",
        "type": "function",
        "z": "f6f2187d.f17ca8",
        "name": "Add deviceerror",
        "func": "var lookup = global.get(\"devicenames\")\nif(msg.succes){\n    lookup[msg.req.params.imei].succes++; \n    global.set(\"devicenames\", lookup);\n    node.status({ fill: \"green\", shape: \"ring\", text: \"name: \" + lookup[msg.req.params.imei].name + \"\\nfailed: \" + lookup[msg.req.params.imei].failed + \"\\tsucces: \" + lookup[msg.req.params.imei].succes });\n    return msg;\n} else{\n    lookup[msg.req.params.imei].failed++; \n    node.status({ fill: \"red\", shape: \"ring\", text: \"name: \" + lookup[msg.req.params.imei].name + \"\\nfailed: \" + lookup[msg.req.params.imei].failed + \"\\tsucces: \" + lookup[msg.req.params.imei].succes });\n    global.set(\"devicenames\", lookup);\n    throw new Error(\"size was to small skipping this picture\");\n}\n\n",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 800,
        "y": 380,
        "wires": [
