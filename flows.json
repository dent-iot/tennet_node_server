        "name": "verify size",
        "func": "msg.filesize = msg.payload.length\nvar lookup = global.get(\"devicenames\");\n\nmsg.succes = false;\nif(msg.filesize < 20e3)\n{\n    node.status({fill:\"red\",shape:\"ring\",text:\"size \"+(msg.filesize/1000) + 'k' });\n    return msg;\n}\nnode.status({ fill: \"green\", shape: \"ring\", text: \"size \" + (msg.filesize / 1000) + 'k' });\nmsg.succes = true;\nlookup[msg.req.params.imei].succes++;\nreturn msg;",
