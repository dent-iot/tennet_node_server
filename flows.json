    {
        "id": "da4fd5903d085e66",
        "type": "function",
        "z": "f6f2187d.f17ca8",
        "name": "verify size",
        "func": "msg.filesize = msg.payload.length\n\nif(msg.filesize < 30e3)\n{\n    node.status({fill:\"red\",shape:\"ring\",text:\"size \"+(msg.filesize/1000) + 'k' });\n    throw \"file \"+msg.video_id+\" too small (\"+msg.filesize+\") for device \" + msg.device_id;\n}\nnode.status({ fill: \"green\", shape: \"ring\", text: \"size \" + (msg.filesize / 1000) + 'k' });\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 780,
        "y": 380,
        "wires": [
