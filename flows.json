        "func": "var lookup = global.get(\"devicenames\")\nif(msg.req.params.imei in lookup){\n    msg.device_id = lookup[msg.req.params.imei].name;\n    msg.project = lookup[msg.req.params.imei].project;\n}\nelse{\n    throw new Error(\"imei number not found skipping this request\");\n}\nif (msg.req.params.imei.includes(\"/\")) {\n    throw new Error(\"imei wildcard contains forbidden characters\");\n}\n\nmsg.video_id=msg.req.params.video_id\n\nnode.status({ fill: \"gray\", shape: \"square\", text: `${msg.project}:${msg.device_id}` });\n\nreturn msg;",
