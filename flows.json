        "func": "const filePath = \"/home/donny/shared_tennet/\";\nconst weekNumber = global.get(\"weekNumber\");\nconst date = new Date();\nconst year = date.getFullYear();\n\n\nmsg.filepath += year + \"_\" + weekNumber\n// Check if the directory exists (basic check)\n\nmsg.payload = 'mkdir -p ' + msg.filepath;\nreturn msg;",
